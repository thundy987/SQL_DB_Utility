
-- =============================================================================
-- Module 1: Backup Status
-- =============================================================================
-- Purpose: Checks backup health across all databases on the instance.
--          Surfaces last full/differential/log backup per database,
--          time since each backup type, and an alert status flag.
--
-- Scope:   Instance-wide. Pulls from msdb.dbo.backupset which aggregates
--          backup history for all databases. No iteration required.
--
-- Sources:
--   msdb.dbo.backupset  - Backup history records including type and finish date
--   sys.databases       - Master list of databases including recovery model;
--                         LEFT JOIN ensures databases with no backup history appear
-- =============================================================================

-- =============================================================================
-- USER CONFIGURATION - adjust thresholds to match your environment
-- =============================================================================
DECLARE @diff_log_time INT = 2;   -- Max hours allowed since last differential or log backup
DECLARE @full_time     INT = 12;  -- Max hours allowed since last full backup
-- =============================================================================

IF OBJECT_ID('dbo.BackupStatus') IS NOT NULL
    DROP TABLE BackupStatus;

create table BackupStatus (
    database_name nvarchar (256),
	recovery_model_desc nvarchar (50),
	last_full_backup_date datetime,
	last_differential_backup datetime,
	last_full_log_date datetime,
	hours_since_full_backup int,
	hours_since_differential_backup int,
	hours_since_log_backup int,
	backup_alert_status nvarchar (50)	
);

WITH backup_info AS (
-- Aggregate most recent backup finish date per database per backup type
Select 
	database_name,
	MAX (
		CASE 
			when type = 'D' then backup_finish_date
			else NULL
		END
		) as last_full_backup_date,
	MAX (
		CASE 
			when type = 'I' then backup_finish_date
			else NULL
		END
		) as last_differential_backup,
	MAX (
		CASE 
			when type = 'L' then backup_finish_date
			else NULL
		END
		) as last_full_log_date
FROM msdb.dbo.backupset
GROUP BY database_name),

backup_details AS(
	-- LEFT JOIN preserves databases that have never been backed up (bi columns will be NULL)
Select 
	d.name as database_name,
	d.recovery_model_desc,
	bi.last_full_backup_date,
	bi.last_differential_backup,
	bi.last_full_log_date,
	datediff (hour, bi.last_full_backup_date, getdate()) as hours_since_full_backup,
	datediff (hour, bi.last_differential_backup, getdate()) as hours_since_differential_backup,
	datediff (hour, bi.last_full_log_date, getdate()) as hours_since_log_backup
from sys.databases as d
Left join backup_info as bi
	on d.name = bi.database_name)

Insert into BackupStatus (
    database_name,
	recovery_model_desc,
	last_full_backup_date,
	last_differential_backup,
	last_full_log_date,
	hours_since_full_backup,
	hours_since_differential_backup,
	hours_since_log_backup ,
	backup_alert_status	
)
-- Final output with alert flag
select 
	 database_name,
	recovery_model_desc,
	last_full_backup_date,
	last_differential_backup,
	last_full_log_date,
	hours_since_full_backup,
	hours_since_differential_backup,
	hours_since_log_backup,
	CASE
		-- tempdb cannot be backed up
		WHEN database_name = 'tempdb' THEN 'Ok'
		when last_full_backup_date is null then 'Full backup never taken!'
		-- FULL recovery model requires frequent log or differential backups
		when recovery_model_desc = 'FULL' and (hours_since_differential_backup > @diff_log_time or hours_since_log_backup > @diff_log_time) then 'Take a log backup'
		-- SIMPLE recovery model only needs full backups monitored
		when recovery_model_desc = 'SIMPLE' and hours_since_full_backup > @diff_log_time then 'Overdue Full Backup'
		-- Catch-all for any backup type overdue (covers BULK_LOGGED and edge cases)
		when hours_since_full_backup > @full_time or hours_since_differential_backup > @full_time or hours_since_log_backup > @full_time then 'Overdue Backup'
		else 'Ok' 
	END as backup_alert_status
FROM backup_details
ORDER BY backup_alert_status DESC, database_name;
