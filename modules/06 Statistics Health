-- =============================================================================
-- Module 6: Statistics Health
-- =============================================================================
-- Purpose: Evaluates statistics staleness across all databases on the instance.
--          Orders results by modification percentage to surface the most at-risk
--          tables first. Also flags statistics that have never been computed.
--
-- Scope:   Iterates through all databases (optionally including system databases).
--          Iteration is required because statistics data is stored at the database
--          level and no DMV aggregates it across databases. A WHILE loop advances
--          alphabetically through sys.databases to avoid gaps from dropped database IDs.
--          Each iteration executes a dynamically built SQL string via sp_executesql.
--
-- Sources:
--   sys.stats                    - One row per statistics object per table
--   sys.dm_db_stats_properties   - Instance-level function returning computation
--                                  metadata per stats object (last updated, rows,
--                                  modification counter). Returns NULL columns for
--                                  never-computed stats rather than dropping the row,
--                                  so CROSS APPLY is safe here.
--   sys.databases                - Used to drive iteration and filter system databases by name
--   sys.objects                  - Connects statistics objects to their parent table
--                                  to resolve schema and table name
-- =============================================================================

-- =============================================================================
-- USER CONFIGURATION - adjust to your preferences
-- =============================================================================
DECLARE @include_system_dbs         BIT   = 1;    -- Set to 1 to include system databases (master, tempdb, model, msdb)
DECLARE @percent_modified_threshold FLOAT = 30.5; -- Flag stats where this % or more of rows have changed since last update
-- =============================================================================

declare @db_name nvarchar (256);
set @db_name = (Select top 1 name from sys.databases
WHERE (@include_system_dbs = 1 OR name not in ('master', 'model', 'msdb', 'tempdb')));

IF OBJECT_ID('dbo.StatisticsHealth') IS NOT NULL
    DROP TABLE StatisticsHealth;

create table StatisticsHealth (
	t_database_name nvarchar (256),
	t_schema_name nvarchar (256),
	t_table_name nvarchar (256),
	t_statistics_name nvarchar (256),
	t_stats_last_updated_datetime datetime,
	t_hours_since_last_stats_update int,
	t_rows_from_latest_stats bigint,
	t_modification_counter bigint,
	t_percent_rows_modified_since_last_stats_update float,
	t_stats_ever_updated_flag nvarchar (100)
);

While @db_name is not null
BEGIN
declare @sql nvarchar(max);

set @sql = N'
with column_grabs as(
Select
	' + '''' + @db_name + '''' + ' AS database_name, -- @db_name concatenated because it cannot be referenced directly (cannot use "use")
	OBJECT_SCHEMA_NAME(c.object_id) AS schema_name,
    OBJECT_NAME(c.object_id) AS table_name,	
	a.name as statistics_name,	
	b.last_updated as stats_last_updated_datetime,
	DATEDIFF(hour, b.last_updated, getdate()) as hours_since_last_stats_update,
	b.rows as rows_from_latest_stats,
	b.modification_counter,
	cast(ROUND ((b.modification_counter * 100.0) / NULLIF(b.rows, 0),1) as float) -- nullif to prevent divide by zero on empty tables.
	as percent_rows_modified_since_last_stats_update,
	CASE
		when b.last_updated is null then ''Statistics have never been updated''
		else null 
	END as stats_ever_updated_flag
FROM ' + @db_name + '.sys.stats AS a
-- CROSS APPLY is safe here: dm_db_stats_properties returns a row with NULL columns
-- for never-computed stats rather than returning no row, so no stats are dropped
cross apply sys.dm_db_stats_properties(a.object_id, a.stats_id) as b -- cross apply used to connect the stats properties to the stats objects. Outer apply returned the same results in testing, but cross apply is more efficient when there is a matching row in the stats properties for each stats object
inner join ' +@db_name+ '.sys.objects AS c 
	ON a.object_id = c.object_id
)

Insert into StatisticsHealth(
t_database_name,
	t_schema_name,
	t_table_name,
	t_statistics_name,
	t_stats_last_updated_datetime,
	t_hours_since_last_stats_update,
	t_rows_from_latest_stats,
	t_modification_counter,
	t_percent_rows_modified_since_last_stats_update,
	t_stats_ever_updated_flag
	)
Select 
	database_name,
	schema_name,
	table_name,
	statistics_name,
	stats_last_updated_datetime,
	hours_since_last_stats_update,
	rows_from_latest_stats,
	modification_counter,
	percent_rows_modified_since_last_stats_update,
	stats_ever_updated_flag
from column_grabs
-- IS NOT NULL catches never-computed stats regardless of threshold
where (percent_rows_modified_since_last_stats_update > @percent_modified_threshold) or stats_ever_updated_flag is not null'

-- @percent_modified_threshold passed as a parameter (not concatenated) to prevent SQL injection
EXEC sp_executesql @sql, 
    N'@percent_modified_threshold FLOAT', 
    @percent_modified_threshold = @percent_modified_threshold

-- Advance to next database alphabetically; returns NULL when list is exhausted, ending the loop
set @db_name =(
Select top 1 name from sys.databases
WHERE (@include_system_dbs = 1 
OR name not in ('master', 'model', 'msdb', 'tempdb')) 
and name > @db_name
Order by name)
END

select * from StatisticsHealth
Order by t_percent_rows_modified_since_last_stats_update desc, t_hours_since_last_stats_update desc;
