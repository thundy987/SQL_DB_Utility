-- =============================================
-- Description: Orchestrates the SQL Server health check suite. Executes any
--              combination of six modules based on input flags. Errors per
--              module are caught and logged to dbo.ErrorLog without halting
--              remaining modules.
-- =============================================

IF OBJECT_ID('dbo.usp_HealthCheck') IS NOT NULL
	DROP PROCEDURE dbo.usp_HealthCheck;
GO


-----------------------------------------------------------------------------------------------------------------------
IF OBJECT_ID('dbo.ErrorLog') IS NULL
BEGIN
   create table ErrorLog(
	ErrorID INT IDENTITY(1,1) NOT NULL PRIMARY KEY,
    ErrorDateTime DATETIME DEFAULT GETDATE(),
	ErrorModuleName NVARCHAR(128),
    ErrorNumber INT,
    ErrorSeverity INT,
    ErrorState INT,
    ErrorProcedure NVARCHAR(128),
    ErrorLine INT,
    ErrorMessage NVARCHAR(4000)
   );
END
GO

CREATE PROCEDURE dbo.usp_HealthCheck 
	@run_backup_status_module bit, -- Set to 1 to run backup status module, 0 to skip
	@diff_log_time int, -- Max hours allowed since last differential or log backup
	@full_time int, -- Max hours allowed since last full backup

	@run_disk_space_module bit, -- Set to 1 to run disk space module, 0 to skip
	@include_system_dbs_disk_space bit, -- Set to 1 to include system databases (master, tempdb, model, msdb)
	@space_warning_threshold int, -- % free space at which to trigger a WARNING alert
	@space_critical_threshold int, -- % free space at which to trigger a CRITICAL alert

	@run_index_frag_module bit, -- Set to 1 to run index fragmentation module, 0 to skip
	@include_system_dbs_index_frag bit,	-- Set to 1 to include system databases (master, tempdb, model, msdb)

	
	@run_missing_index_module bit, -- Set to 1 to run missing index module, 0 to skip
	@priority_threshold float, -- Minimum priority score to report. Higher = more impactful suggestions only.

	@run_long_running_queries_module bit, -- Set to 1 to run long-running queries module, 0 to skip
	@threshold_critical int, -- seconds before flagging as Critical
	@threshold_warning int, -- seconds before flagging as Warning

	@run_statistics_health_module bit, -- Set to 1 to run statistics health module, 0 to skip
	@include_system_dbs_statistics bit, -- Set to 1 to include system databases (master, tempdb, model, msdb)
	@percent_modified_threshold float -- Flag stats where this % or more of rows have changed since last update
AS
BEGIN

IF @run_backup_status_module = 1
BEGIN
	BEGIN TRY
		EXEC dbo.usp_BackupStatus @diff_log_time = @diff_log_time, @full_time = @full_time;
	END TRY
	BEGIN CATCH
		INSERT INTO dbo.ErrorLog (
			ErrorModuleName,
			ErrorNumber,
			ErrorDateTime,
			ErrorSeverity,
			ErrorState,
			ErrorProcedure,
			ErrorLine,
			ErrorMessage
		)
		SELECT
			'usp_BackupStatus' as ErrorModuleName,
			ERROR_NUMBER(),
			GETDATE() as ErrorDateTime,
			ERROR_SEVERITY(),
			ERROR_STATE(),
			ERROR_PROCEDURE(),
			ERROR_LINE(),
			ERROR_MESSAGE();
		PRINT ' error has occured with usp_BackupStatus module and has been added to dbo.ErrorLog';
	END CATCH
END
if @run_disk_space_module = 1
BEGIN	
	BEGIN TRY
	EXEC dbo.usp_DiskSpaceMonitor @space_warning_threshold = @space_warning_threshold, @space_critical_threshold = @space_critical_threshold, @include_system_dbs_disk_space = @include_system_dbs_disk_space;
	END TRY
	BEGIN CATCH
		INSERT INTO dbo.ErrorLog (
			ErrorModuleName,
			ErrorNumber,
			ErrorDateTime,
			ErrorSeverity,
			ErrorState,
			ErrorProcedure,
			ErrorLine,
			ErrorMessage
		)
		SELECT
			'usp_DiskSpaceMonitor' as ErrorModuleName,
			ERROR_NUMBER(),
			GETDATE() as ErrorDateTime,
			ERROR_SEVERITY(),
			ERROR_STATE(),
			ERROR_PROCEDURE(),
			ERROR_LINE(),
			ERROR_MESSAGE();
		PRINT ' error has occured with usp_DiskSpaceMonitor module and has been added to dbo.ErrorLog';
	END CATCH
END
IF @run_index_frag_module = 1
BEGIN
	BEGIN TRY
	EXEC dbo.usp_IndexFragmentationMonitor @include_system_dbs_index_frag = @include_system_dbs_index_frag;
	END TRY
	BEGIN CATCH
		INSERT INTO dbo.ErrorLog (
			ErrorModuleName,
			ErrorNumber,
			ErrorDateTime,
			ErrorSeverity,
			ErrorState,
			ErrorProcedure,
			ErrorLine,
			ErrorMessage
		)
		SELECT
			'usp_IndexFragmentationMonitor' as ErrorModuleName,
			ERROR_NUMBER(),
			GETDATE() as ErrorDateTime,
			ERROR_SEVERITY(),
			ERROR_STATE(),
			ERROR_PROCEDURE(),
			ERROR_LINE(),
			ERROR_MESSAGE();
		PRINT ' error has occured with usp_IndexFragmentationMonitor module and has been added to dbo.ErrorLog';
	END CATCH
END
IF @run_missing_index_module = 1
BEGIN
	BEGIN TRY
	EXEC dbo.usp_MissingIndexMonitor @priority_threshold = @priority_threshold;
	END TRY
	BEGIN CATCH
		INSERT INTO dbo.ErrorLog (
			ErrorModuleName,
			ErrorNumber,
			ErrorDateTime,
			ErrorSeverity,
			ErrorState,
			ErrorProcedure,
			ErrorLine,
			ErrorMessage
		)
		SELECT
			'usp_MissingIndexMonitor' as ErrorModuleName,
			ERROR_NUMBER(),
			GETDATE() as ErrorDateTime,
			ERROR_SEVERITY(),
			ERROR_STATE(),
			ERROR_PROCEDURE(),
			ERROR_LINE(),
			ERROR_MESSAGE();
		PRINT ' error has occured with usp_MissingIndexMonitor module and has been added to dbo.ErrorLog';
	END CATCH
END
IF @run_long_running_queries_module = 1
BEGIN
	BEGIN TRY
	EXEC dbo.usp_LongRunningQueries @threshold_critical = @threshold_critical, @threshold_warning = @threshold_warning;
	END TRY
	BEGIN CATCH
		INSERT INTO dbo.ErrorLog (
			ErrorModuleName,
			ErrorNumber,
			ErrorDateTime,
			ErrorSeverity,
			ErrorState,
			ErrorProcedure,
			ErrorLine,
			ErrorMessage
		)
		SELECT
			'usp_LongRunningQueries' as ErrorModuleName,
			ERROR_NUMBER(),
			GETDATE() as ErrorDateTime,
			ERROR_SEVERITY(),
			ERROR_STATE(),
			ERROR_PROCEDURE(),
			ERROR_LINE(),
			ERROR_MESSAGE();
		PRINT ' error has occured with usp_LongRunningQueries module and has been added to dbo.ErrorLog';
	END CATCH
END
IF @run_statistics_health_module = 1
BEGIN
	BEGIN TRY
	EXEC dbo.usp_StatisticsHealth @percent_modified_threshold = @percent_modified_threshold, @include_system_dbs_statistics = @include_system_dbs_statistics;
	END TRY
	BEGIN CATCH
		INSERT INTO dbo.ErrorLog (
			ErrorModuleName,
			ErrorNumber,
			ErrorDateTime,
			ErrorSeverity,
			ErrorState,
			ErrorProcedure,
			ErrorLine,
			ErrorMessage
		)
		SELECT
			'usp_StatisticsHealth' as ErrorModuleName,
			ERROR_NUMBER(),
			GETDATE() as ErrorDateTime,
			ERROR_SEVERITY(),
			ERROR_STATE(),
			ERROR_PROCEDURE(),
			ERROR_LINE(),
			ERROR_MESSAGE();
		PRINT ' error has occured with usp_StatisticsHealth module and has been added to dbo.ErrorLog';
	END CATCH
END
IF @run_backup_status_module = 0 AND @run_disk_space_module = 0 AND @run_index_frag_module = 0 AND @run_missing_index_module = 0 AND @run_long_running_queries_module = 0 AND @run_statistics_health_module = 0
BEGIN
	PRINT 'No modules selected to run. Please set at least one @run_ parameter to 1 to execute a health check module.';
END
END
