-- =============================================
-- Description: Identifies missing indexes recommended by SQL Server based on
--              query patterns since last service restart. Builds a suggested
--              CREATE INDEX statement for each result.
-- Note:        Priority score is a custom metric, not an official Microsoft value.
--              DMV data resets on SQL Server restart.
-- =============================================

if OBJECT_ID('dbo.usp_MissingIndexMonitor') IS NOT NULL
	drop procedure dbo.usp_MissingIndexMonitor;
GO

CREATE PROCEDURE dbo.usp_MissingIndexMonitor
	@priority_threshold FLOAT
AS
BEGIN

IF OBJECT_ID('dbo.MissingIndexMonitor') IS NULL
BEGIN
create table MissingIndexMonitor (
	missing_index_id int identity(1,1) primary key,
	scan_date datetime default getdate(),
    table_name nvarchar (256),
	priority float,
	estimated_percent_improvement float,
	avg_total_user_cost float,
	user_seeks int,
	user_scans int,
	index_suggestion nvarchar (max)	
);
END;

WITH cte_missing_indexes AS (
select 
	details.statement as table_name,
	 -- Priority score: (seeks + scans) * avg impact * avg cost. Higher = fix first.
	ROUND (CAST ((stat.user_seeks + stat.user_scans) * stat.avg_user_impact * stat.avg_total_user_cost AS float), 1)  AS priority,
	ROUND (stat.avg_user_impact, 2) as Estimated_percent_improvement,
	ROUND (stat.avg_total_user_cost, 2) as avg_total_user_cost,
	stat.user_seeks,
	stat.user_scans,
	 -- Dynamically build a CREATE INDEX statement from DMV column suggestions.
     -- Equality columns (=) always precede inequality columns (>, <) per index design best practice.
     -- INCLUDE columns allow the index to cover the full query without a key lookup.
	'CREATE NON-CLUSTERED INDEX suggested_index_' + 
		CONVERT (varchar, groups.index_group_handle) + '_' + 
		CONVERT (varchar, groups.index_handle) + ' ON ' + details.statement + ' (' +
	CASE
		when details.equality_columns IS NOT NULL and details.inequality_columns IS NULL then details.equality_columns 
		when details.equality_columns IS NOT NULL and details.inequality_columns IS NOT NULL then details.equality_columns + ', ' + details.inequality_columns
		else details.inequality_columns
	END + ')' +
	ISNULL (' INCLUDE (' + details.included_columns + ')', '')	as index_suggestion
	from sys.dm_db_missing_index_groups as groups
inner join sys.dm_db_missing_index_group_stats as stat
	on groups.index_group_handle = stat.group_handle
inner join sys.dm_db_missing_index_details as details
	on groups.index_handle = details.index_handle)

Insert into MissingIndexMonitor (
	table_name,
	priority,
	estimated_percent_improvement,
	avg_total_user_cost,
	user_seeks,
	user_scans,
	index_suggestion
)

select 
	table_name,
	priority,
	estimated_percent_improvement,
	avg_total_user_cost,
	user_seeks,
	user_scans,
	index_suggestion
from cte_missing_indexes
where priority > @priority_threshold
END
